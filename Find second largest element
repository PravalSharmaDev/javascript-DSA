function Slargest(arr){
if(arr.length < 2 ) return "Array have atleast two elements";
let first = - Infinity;
let second = - Infinity;
for(let i = 0; i<arr.length; i++){
   if(arr[i]>first){
      second = first;
      first = arr[i];
    }
else if (arr[i]>second && arr[i]!==first){
second  = arr[i];
    }
}
return second;
}
let arr = [10 , 20 , 8 , 9 , 3 , 20 ];
let result = Slargest(arr);
console.log(result);
